# nsh-vault-deploy Configuration
# Copy to .env at project root and adjust before running provisioners.
# .env is gitignored — never commit it.

# ── Vault Server Setup ────────────────────────────────────────────────────────
# FQDN of the Vault server.
# Used by: TLS bootstrap certificate, Vault api_addr, PKI issuer/CRL/OCSP URLs,
#          ACME cluster path.
# Must be the hostname clients use to reach this server — no loopback names.
VAULT_FQDN=vault.example.com

# Public HTTPS port on the host. Use 443 for standard HTTPS.
# The container always listens on 8200 internally.
VAULT_HTTPS_PORT=443

# ── Vault Provisioning Configuration ──────────────────────────────────────────
# Internal connection address for terminal/provisioner scripts.
# Used during setup and configuration. Always localhost for local connections.
VAULT_ADDR=http://127.0.0.1:8100

# Root token from server/init/setup.sh output.
# If empty, auto-loaded from server/init/vault-init.json
VAULT_TOKEN=

# ── External public URL (written into certificates) ──────────────────────────
# The address that external clients use to reach Vault.
# Must be HTTPS and reachable by certificate validation clients.
# Examples: https://vault.example.com, https://localhost, https://127.0.0.1:8200
# Built from VAULT_FQDN and VAULT_HTTPS_PORT above.
#   Port 443:  VAULT_API_ADDR=https://vault.example.com
#   Port 8200: VAULT_API_ADDR=https://vault.example.com:8200
VAULT_API_ADDR=https://localhost

# ── Certificate domain ────────────────────────────────────────────────────────
# Domain for which Vault will issue certificates.
# Used in PKI role allowed_domains (allow_subdomains=true covers all FQDNs
# under this domain, e.g. domino.example.com, web.example.com).
# Set to your actual domain — not vault's own hostname.
VAULT_DOMAIN=localhost

# ── ACME challenge DNS (optional) ─────────────────────────────────────────────
# Vault validates ACME challenges from inside the Docker container.
# If your target domains are on an internal DNS server, uncomment below and
# edit docker-compose.yml to add the DNS server.
# (docker-compose.yml does not read this directly — edit it manually.)
# INTERNAL_DNS=192.168.1.1
