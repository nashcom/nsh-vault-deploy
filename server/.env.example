# server/.env.example
# Copy to server/.env and adjust before running docker compose.
# server/.env is gitignored — never commit it.

# ── External address ──────────────────────────────────────────────────────────
# FQDN of this Vault server (used in TLS bootstrap cert and PKI URLs)
VAULT_FQDN=vault.example.com

# Public HTTPS port on the host. Use 443 for standard HTTPS.
# The container always listens on 8200 internally.
VAULT_HTTPS_PORT=443

# Full public URL for Vault API.
# This is what external clients (ACME, Vault Agent, curl) use to reach Vault.
# Must be reachable from the outside — no loopback addresses here.
#   Port 443:  VAULT_API_ADDR=https://vault.example.com
#   Port 8200: VAULT_API_ADDR=https://vault.example.com:8200
VAULT_API_ADDR=https://vault.example.com
