# ── Configuration (user-specific, never commit) ──────────────────────────
.env
/.env

# ── Vault init / credentials (never commit) ───────────────────────────────
server/init/vault-init.json
server/init/certmgr-approle.env
server/init/vault-tls-approle.env

# ── Generated credentials (per-server, never commit) ───────────────────────
server/provisioners/*/credentials/
client/nginx/credentials/

# ── TLS certificates and keys ─────────────────────────────────────────────
**/*.crt
**/*.key
**/*.pem
**/*.csr
**/*.srl

# ── Build artifacts ────────────────────────────────────────────────────────
*.o
*.a
client/cpp_client/vault_example
client/cpp_client/example
client/domino/curltest/curltest
client/vault-fetcher/vault-fetcher

# ── Runtime / local data ──────────────────────────────────────────────────
server/vault-data/
server/vault-logs/

# ── Leftover Dockerfiles ───────────────────────────────────────────────────
server/Dockerfile_Alpine
